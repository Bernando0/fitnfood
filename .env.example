# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI-compatible LLM endpoint (alem.ai / Gemma)
LLM_BASE_URL=https://llm.alem.ai/v1
LLM_API_KEY=
LLM_MODEL=gemma4

# Optional: restrict the bot to a single group chat id (leave empty to allow any)
ALLOWED_CHAT_ID=

# Timezone for the daily report (IANA name, e.g. Europe/Moscow, Asia/Almaty)
TZ=Europe/Moscow

# Hour (0-23, local TZ) to send the end-of-day report
DAILY_REPORT_HOUR=22

# Path to the SQLite database file
DB_PATH=data/fitfood.db
